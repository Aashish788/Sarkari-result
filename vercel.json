{
  "buildCommand": "CI=false npm run build",
  "rewrites": [
    { "source": "/job/:id", "destination": "/job.html" },
    { "source": "/((?!\\.well-known/).)*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
